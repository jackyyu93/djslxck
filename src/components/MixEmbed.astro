---
export interface Props {
  title: string;
  description?: string;
  /** SoundCloud track URL, e.g. https://soundcloud.com/djslxck/your-mix */
  soundcloudUrl?: string;
  /** Or a YouTube video ID */
  youtubeId?: string;
}

const { title, description, soundcloudUrl, youtubeId } = Astro.props;
---

<div
  class="overflow-hidden rounded-2xl border border-border bg-surface card-hover"
  data-reveal
>
  <div class="aspect-video bg-bg">
    {
      soundcloudUrl ? (
        <iframe
          width="100%"
          height="100%"
          allow="autoplay"
          src={`https://w.soundcloud.com/player/?url=${encodeURIComponent(soundcloudUrl)}&color=%23ff006e&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false&visual=true`}
        />
      ) : youtubeId ? (
        <iframe
          width="100%"
          height="100%"
          src={`https://www.youtube.com/embed/${youtubeId}`}
          title={title}
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        />
      ) : (
        <div class="flex h-full items-center justify-center text-muted">
          <span class="text-sm uppercase tracking-widest">Mix coming soon</span>
        </div>
      )
    }
  </div>
  <div class="p-6">
    <h3 class="display-md text-text">{title}</h3>
    {description && <p class="mt-2 text-sm text-muted">{description}</p>}
  </div>
</div>
