---
export interface Props {
  eyebrow?: string;
  title?: string;
  subtitle?: string;
  image?: string;
  imageMobile?: string;
}

const {
  eyebrow = "Open Format · High Energy",
  title = "DJ SLXCK",
  subtitle = "Beats that move crowds. Energy that lasts the night.",
  image = "https://images.unsplash.com/photo-1571266028243-d220bc2dccb4?auto=format&fit=crop&w=1600&q=75",
  imageMobile = "https://images.unsplash.com/photo-1571266028243-d220bc2dccb4?auto=format&fit=crop&w=900&q=70",
} = Astro.props;
---

<section
  class="relative -mt-20 flex min-h-screen items-center overflow-hidden"
  data-hero
>
  <!-- Background image with parallax -->
  <div class="absolute inset-0 z-0" data-hero-bg>
    <picture>
      <source media="(max-width: 768px)" srcset={imageMobile} />
      <img
        src={image}
        alt=""
        class="h-[110%] w-full object-cover will-change-transform"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        data-hero-image
      />
    </picture>
    <!-- Layered overlays for depth -->
    <div
      class="absolute inset-0 bg-gradient-to-b from-bg/60 via-bg/55 to-bg"
    ></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_25%_35%,rgba(255,0,110,0.25),transparent_55%)]"
    ></div>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_80%_70%,rgba(255,0,110,0.10),transparent_50%)]"
    ></div>
    <!-- Vignette -->
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_50%,rgba(0,0,0,0.5)_100%)]"
    ></div>
  </div>

  <!-- Content -->
  <div class="container-x relative z-10 pt-24">
    <div class="max-w-4xl">
      <p class="eyebrow opacity-0" data-hero-eyebrow>{eyebrow}</p>
      <h1 class="display-xl mt-6 text-text opacity-0" data-hero-title>
        {title}
      </h1>
      <p
        class="mt-8 max-w-xl text-lg text-muted opacity-0 sm:text-xl"
        data-hero-subtitle
      >
        {subtitle}
      </p>
      <div class="mt-10 flex flex-wrap gap-4 opacity-0" data-hero-ctas>
        <a href="/contact" class="btn-primary">Book Your Event</a>
        <a href="/portfolio" class="btn-ghost">Hear the Mixes</a>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div
    class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2 text-muted opacity-0"
    data-hero-cue
  >
    <div class="flex flex-col items-center gap-2">
      <span class="text-xs uppercase tracking-widest">Scroll</span>
      <div class="h-10 w-px bg-gradient-to-b from-accent to-transparent"></div>
    </div>
  </div>
</section>

<script>
  // Hero entrance animation — staggered fade+rise
  const animate = (el: Element | null, delay: number) => {
    if (!el) return;
    const target = el as HTMLElement;
    target.style.transform = "translateY(24px)";
    target.style.transition = `opacity 0.9s ease-out ${delay}ms, transform 0.9s cubic-bezier(0.16, 1, 0.3, 1) ${delay}ms`;
    requestAnimationFrame(() => {
      target.style.opacity = "1";
      target.style.transform = "translateY(0)";
    });
  };

  const onReady = () => {
    animate(document.querySelector("[data-hero-eyebrow]"), 100);
    animate(document.querySelector("[data-hero-title]"), 250);
    animate(document.querySelector("[data-hero-subtitle]"), 500);
    animate(document.querySelector("[data-hero-ctas]"), 700);
    animate(document.querySelector("[data-hero-cue]"), 1100);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", onReady);
  } else {
    onReady();
  }

  // Subtle parallax on the hero background — translate3d only, GPU-accelerated
  // Skipped on touch devices, reduced-motion users, and small screens
  const heroImage = document.querySelector(
    "[data-hero-image]"
  ) as HTMLElement | null;
  const heroSection = document.querySelector("[data-hero]") as HTMLElement | null;

  const enableParallax =
    heroImage &&
    heroSection &&
    !window.matchMedia("(prefers-reduced-motion: reduce)").matches &&
    !window.matchMedia("(hover: none)").matches &&
    window.innerWidth >= 1024;

  if (enableParallax) {
    let ticking = false;
    let lastOffset = 0;

    const update = () => {
      const rect = heroSection.getBoundingClientRect();
      // Only animate while hero is at all visible
      if (rect.bottom > 0 && rect.top < window.innerHeight) {
        const offset = Math.max(0, -rect.top) * 0.2;
        if (Math.abs(offset - lastOffset) > 0.5) {
          heroImage.style.transform = `translate3d(0, ${offset}px, 0)`;
          lastOffset = offset;
        }
      }
      ticking = false;
    };

    window.addEventListener(
      "scroll",
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
    update();
  }

  // Fade out scroll cue once user starts scrolling
  const scrollCue = document.querySelector("[data-hero-cue]") as HTMLElement | null;
  if (scrollCue) {
    let cueHidden = false;
    window.addEventListener(
      "scroll",
      () => {
        if (!cueHidden && window.scrollY > 80) {
          cueHidden = true;
          scrollCue.style.transition = "opacity 0.4s ease-out";
          scrollCue.style.opacity = "0";
        } else if (cueHidden && window.scrollY <= 20) {
          cueHidden = false;
          scrollCue.style.opacity = "1";
        }
      },
      { passive: true }
    );
  }
</script>
