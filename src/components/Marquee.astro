---
export interface Props {
  items: string[];
}

const { items } = Astro.props;
// duplicate items for seamless loop
const tracks = [...items, ...items];
---

<div class="relative overflow-hidden border-y border-border bg-surface py-10">
  <div class="marquee-track gap-16 whitespace-nowrap">
    {
      tracks.map((item) => (
        <span class="font-display text-3xl uppercase tracking-widest text-muted">
          {item}
          <span class="mx-8 inline-block text-accent">✦</span>
        </span>
      ))
    }
  </div>
  <div
    class="pointer-events-none absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-surface to-transparent"
  ></div>
  <div
    class="pointer-events-none absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-surface to-transparent"
  ></div>
</div>
