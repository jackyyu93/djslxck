---
import "@/styles/global.css";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "DJ SLXCK — Beats. Energy. Unforgettable.",
  description = "DJ Slxck delivers high-energy sets for weddings, private events, and clubs. Book now to make your event unforgettable.",
  image = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="DJ SLXCK" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="DJ SLXCK — Beats. Energy. Unforgettable." />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url)} />
    <meta name="twitter:image:alt" content="DJ SLXCK — Beats. Energy. Unforgettable." />

    <!-- iMessage / Apple rich preview hint -->
    <meta name="apple-mobile-web-app-title" content="DJ SLXCK" />
    <meta name="application-name" content="DJ SLXCK" />

    <meta name="theme-color" content="#0A0A0A" />

    <!-- Perf: preconnect to image CDN -->
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-accent focus:px-4 focus:py-2 focus:text-bg"
    >
      Skip to content
    </a>

    <Nav />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <script>
      import Lenis from "lenis";

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      // Smooth scroll — disabled if user prefers reduced motion
      // Also skip on touch devices where native scroll is better
      const isTouch = window.matchMedia("(hover: none)").matches;
      if (!prefersReducedMotion && !isTouch) {
        const lenis = new Lenis({
          duration: 0.8,
          easing: (t) => 1 - Math.pow(1 - t, 3), // ease-out cubic, faster settle
          wheelMultiplier: 1.1,
          touchMultiplier: 1.5,
          syncTouch: false,
        });

        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      // Scroll-reveal observer — staggered fade-rise on enter
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = Number(el.dataset.revealDelay ?? i * 60);
              el.style.transition = `opacity 0.8s ease-out ${delay}ms, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1) ${delay}ms`;
              requestAnimationFrame(() => {
                el.style.opacity = "1";
                el.style.transform = "translateY(0)";
              });
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: "0px 0px -50px 0px" }
      );

      document.querySelectorAll("[data-reveal]").forEach((el) => {
        const target = el as HTMLElement;
        target.style.opacity = "0";
        target.style.transform = "translateY(28px)";
        io.observe(target);
      });
    </script>
  </body>
</html>
