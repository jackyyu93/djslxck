---
import BaseLayout from "@/layouts/BaseLayout.astro";

const photos = [
  "https://images.unsplash.com/photo-1571266028243-d220bc2dccb4?auto=format&fit=crop&w=1200&q=85",
  "https://images.unsplash.com/photo-1493676304819-0d7a8d026dcf?auto=format&fit=crop&w=1200&q=85",
  "https://images.unsplash.com/photo-1583244532610-2a234c01ba24?auto=format&fit=crop&w=1200&q=85",
  "https://images.unsplash.com/photo-1574391884720-bbc049ec09ad?auto=format&fit=crop&w=1200&q=85",
  "https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=1200&q=85",
  "https://images.unsplash.com/photo-1492684223066-81342ee5ff30?auto=format&fit=crop&w=1200&q=85",
  "https://images.unsplash.com/photo-1459749411175-04bf5292ceea?auto=format&fit=crop&w=1200&q=85",
  "https://images.unsplash.com/photo-1470225620780-dba8ba36b745?auto=format&fit=crop&w=1200&q=85",
  "https://images.unsplash.com/photo-1545128485-c400ce7b6892?auto=format&fit=crop&w=1200&q=85",
];
---

<BaseLayout title="Gallery — DJ SLXCK">
  <section class="container-x py-20 md:py-28">
    <div class="max-w-3xl">
      <p class="eyebrow" data-reveal>Gallery</p>
      <h1 class="display-xl mt-4 text-text" data-reveal>In the Booth</h1>
      <p class="mt-8 text-xl text-muted" data-reveal>
        Moments from the floor. Crowds, venues, lights, and the work behind the deck.
      </p>
    </div>
  </section>

  <section class="container-x pb-24 md:pb-32">
    <div class="columns-2 gap-4 md:columns-3 [&>*]:mb-4">
      {
        photos.map((src, i) => (
          <img
            src={src}
            alt={`Gallery image ${i + 1}`}
            class="w-full rounded-xl object-cover transition-transform duration-500 hover:scale-[1.02]"
            loading="lazy"
          />
        ))
      }
    </div>
    <p class="mt-12 text-center text-sm text-muted">
      Placeholder images — replace with real photos once provided.
    </p>
  </section>
</BaseLayout>
