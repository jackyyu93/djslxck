---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ServiceCard from "@/components/ServiceCard.astro";

const services = [
  {
    href: "/services/weddings",
    title: "Weddings",
    description:
      "Ceremony, cocktail, reception. Smooth transitions across every moment of the night.",
    image:
      "https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=1200&q=80",
  },
  {
    href: "/services/private",
    title: "Private Events",
    description:
      "Birthdays, milestones, holiday parties. Custom sets dialed to your guests.",
    image:
      "https://images.unsplash.com/photo-1492684223066-81342ee5ff30?auto=format&fit=crop&w=1200&q=80",
  },
  {
    href: "/services/corporate",
    title: "Corporate & Clubs",
    description:
      "Brand activations, residencies, festivals. Pro setup. Pro sound. Pro execution.",
    image:
      "https://images.unsplash.com/photo-1429962714451-bb934ecdc4ec?auto=format&fit=crop&w=1200&q=80",
  },
];
---

<BaseLayout title="Services — DJ SLXCK">
  <section class="container-x py-20 md:py-28">
    <div class="max-w-3xl">
      <p class="eyebrow" data-reveal>Services</p>
      <h1 class="display-xl mt-4 text-text" data-reveal>What I Do</h1>
      <p class="mt-8 text-xl text-muted" data-reveal>
        Every event gets a custom set, a pro-grade setup, and energy that doesn't dip.
      </p>
    </div>
  </section>

  <section class="container-x pb-24 md:pb-32">
    <div class="grid gap-6 md:grid-cols-3">
      {services.map((s) => <ServiceCard {...s} />)}
    </div>
  </section>
</BaseLayout>
