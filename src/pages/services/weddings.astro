---
import BaseLayout from "@/layouts/BaseLayout.astro";

const includes = [
  "Pre-event consultation & timeline planning",
  "Ceremony, cocktail hour & reception coverage",
  "MC services & announcements",
  "Custom playlist curation with do-play / do-not-play lists",
  "Professional grade sound + wireless mics",
  "Dance floor lighting (optional add-on)",
  "Backup equipment on-site",
];
---

<BaseLayout
  title="Wedding DJ — DJ SLXCK"
  description="Book DJ Slxck for your wedding. Custom playlists, professional MC, full-night coverage."
>
  <section class="container-x py-20 md:py-28">
    <div class="grid gap-12 md:grid-cols-2 md:items-center">
      <div data-reveal>
        <p class="eyebrow">Weddings</p>
        <h1 class="display-xl mt-4 text-text">
          Your <span class="text-accent">day.</span><br />
          Your <span class="text-accent">night.</span>
        </h1>
        <p class="mt-8 text-lg text-muted">
          A wedding only happens once. The music shouldn't be left to chance. From the first kiss to the last call, DJ Slxck builds a soundtrack that fits your story and keeps the floor full.
        </p>
        <a href="/contact" class="btn-primary mt-10">Check Availability</a>
      </div>
      <img
        src="https://images.unsplash.com/photo-1519225421980-715cb0215aed?auto=format&fit=crop&w=1400&q=80"
        alt="Wedding reception"
        class="aspect-[4/5] rounded-2xl object-cover"
        loading="lazy"
        data-reveal
      />
    </div>
  </section>

  <section class="border-t border-border bg-surface">
    <div class="container-x py-20 md:py-28">
      <p class="eyebrow" data-reveal>What's Included</p>
      <h2 class="display-lg mt-4 text-text" data-reveal>Every Wedding Package</h2>

      <ul class="mt-12 grid gap-4 md:grid-cols-2" data-reveal>
        {
          includes.map((item) => (
            <li class="flex items-start gap-4 rounded-xl border border-border bg-bg p-5">
              <span class="mt-1 inline-flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-accent text-bg">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </span>
              <span class="text-text">{item}</span>
            </li>
          ))
        }
      </ul>

      <div class="mt-12">
        <a href="/contact" class="btn-primary">Get a Quote</a>
      </div>
    </div>
  </section>
</BaseLayout>
