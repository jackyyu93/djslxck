---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Corporate & Clubs — DJ SLXCK"
  description="Brand activations, corporate events, and club residencies with DJ Slxck."
>
  <section class="container-x py-20 md:py-28">
    <div class="grid gap-12 md:grid-cols-2 md:items-center">
      <div data-reveal>
        <p class="eyebrow">Corporate & Clubs</p>
        <h1 class="display-xl mt-4 text-text">
          Pro-grade <span class="text-accent">execution.</span>
        </h1>
        <p class="mt-8 text-lg text-muted">
          Brand activations, holiday parties, conference after-hours, club residencies. Clean setup, pro sound, and a set tuned to your audience.
        </p>
        <a href="/contact" class="btn-primary mt-10">Inquire</a>
      </div>
      <img
        src="https://images.unsplash.com/photo-1429962714451-bb934ecdc4ec?auto=format&fit=crop&w=1400&q=80"
        alt="Club event"
        class="aspect-[4/5] rounded-2xl object-cover"
        loading="lazy"
        data-reveal
      />
    </div>
  </section>

  <section class="border-t border-border bg-surface">
    <div class="container-x py-20 md:py-28 text-center">
      <p class="eyebrow" data-reveal>Trusted By</p>
      <h2 class="display-lg mx-auto mt-4 max-w-2xl text-text" data-reveal>
        Placeholder partner logos.
      </h2>
      <p class="mt-6 text-muted" data-reveal>
        Replace with real client/venue logos once available.
      </p>
    </div>
  </section>
</BaseLayout>
